# ═══════════════════════════════════════════════════════════════════════════
#  FanVault – Root Environment Variables
#  Copy this file to .env and fill in your actual values.
#  This file is consumed by docker-compose.yml
# ═══════════════════════════════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=fanvault_admin
MONGO_ROOT_PASS=change_this_secure_password_123

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Internal service-to-service secret ───────────────────────────────────────
INTERNAL_SECRET=change_this_internal_secret_min_32_chars

# ── SMTP (Email) ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM=FanVault Store <noreply@fanvault.store>

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production set this to your actual domain
CORS_ORIGIN=http://localhost
