# Email Service Environment Variables

# Server
PORT=3005
NODE_ENV=production

# SMTP Configuration (fill with your provider details)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=FanVault Store <noreply@fanvault.store>

# Internal service secret (must match other services)
INTERNAL_SECRET=internal_service_secret_change_in_production

# Development Ethereal (optional – auto-used when NODE_ENV != production)
ETHEREAL_USER=
ETHEREAL_PASS=
